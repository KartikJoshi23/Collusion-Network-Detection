# Copy to .env and fill in YOUR OWN values on THIS machine. Never commit .env.
# Keys are per-machine and per-developer (implementation-plan.md R18, handoff-prompt.md).

# ── Phase 2 — Investigator Copilot (not needed before Week 11) ──────
OPENAI_API_KEY=
# Optional cheaper model for validator agents (§4.6)
COPILOT_VALIDATOR_MODEL=

# ── Experiment tracking ──────────────────────────────────────────────
# Use "offline" if you have no W&B account or no connectivity.
WANDB_MODE=offline
WANDB_API_KEY=

# ── Kaggle (IBM AMLworld download) ───────────────────────────────────
# Preferred: place kaggle.json at %USERPROFILE%\.kaggle\kaggle.json
# Alternative: set both variables below.
KAGGLE_USERNAME=
KAGGLE_KEY=
