# Copy to .env and fill in YOUR OWN values on THIS machine. Never commit .env.
# Keys are per-machine and per-developer (implementation-plan.md R18, handoff-prompt.md).

# ── Phase 2 — Investigator Copilot (Week 11, §4.6) ──────────────────
# Preferred: NVIDIA NIM (free Developer Program credits, OpenAI-compatible,
# endpoint https://integrate.api.nvidia.com/v1). ONE nvapi-… key covers the
# ENTIRE build.nvidia.com catalog — keys are account-scoped, not per-model:
# create it once at build.nvidia.com/settings/api-keys (or any model page →
# "Get API Key"). Free tier: 1,000 credits (5,000 on request), 40 req/min;
# credits are consumed per REQUEST regardless of model size, so model choice
# is about quality/latency, not cost. OpenAI key is the fallback provider.
NVIDIA_API_KEY=
OPENAI_API_KEY=
# Model overrides — LEAVE BLANK to use the pinned defaults in
# backend/copilot/config.py (2026-07-18 decision, ids verified against the
# live /v1/models catalog): main agent nvidia/nemotron-3-super-120b-a12b
# (first-class OpenAI-style tool calling for the SQL agent + grounding gates),
# validators nvidia/nemotron-3-nano-30b-a3b (3B-active MoE — per-response
# latency under the 40 RPM cap).
COPILOT_MODEL=
COPILOT_VALIDATOR_MODEL=

# ── Experiment tracking ──────────────────────────────────────────────
# Use "offline" if you have no W&B account or no connectivity.
WANDB_MODE=offline
WANDB_API_KEY=

# ── Kaggle (IBM AMLworld download) ───────────────────────────────────
# Preferred: a new-style API token (kaggle.com -> Settings -> API), OR
# place kaggle.json at %USERPROFILE%\.kaggle\kaggle.json, OR set the
# legacy username/key pair.
KAGGLE_API_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
